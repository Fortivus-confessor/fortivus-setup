# Configurações de Infraestrutura Local - FORTIVUS V2
# Centralização de segredos para facilitar a manutenção e segurança

# 1. Banco de Dados (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=fortivus_local_password
POSTGRES_DB=fortivus
POSTGRES_PORT=5444

# 2. Segurança (Keycloak)
KEYCLOAK_POSTGRES_DB=keycloak

# 3. Cache (Redis)
REDIS_PORT=6379

# 4. Observabilidade (Grafana)
GRAFANA_ADMIN_PASSWORD=admin

# 5. Storage (SeaweedFS)
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_MASTER_PORT=9333
