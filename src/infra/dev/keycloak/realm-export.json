{
  "realm": "fortivus",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "clients": [
    {
      "clientId": "fortivus-web",
      "name": "Fortivus Web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "bearerOnly": false,
      "frontchannelLogout": true,
      "redirectUris": ["*"],
      "webOrigins": ["+"],
      "attributes": {
        "post.logout.redirect.uris": "*",
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "roles": {
    "realm": [
      { "name": "ROLE_ADMIN",                  "description": "Administrador do sistema" },
      { "name": "ROLE_CENTRO_COMANDO_CENTRAL", "description": "Comandante Central" },
      { "name": "ROLE_CENTRO_COMANDO",         "description": "Operador de Centro de Comando" },
      { "name": "ROLE_COMBATENTE",             "description": "Combatente de Campo" }
    ]
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@fortivus.gov.br",
      "firstName": "Administrador",
      "lastName": "Geral",
      "credentials": [
        { "type": "password", "value": "123456", "temporary": false }
      ],
      "realmRoles": ["ROLE_ADMIN"]
    },
    {
      "username": "comandante",
      "enabled": true,
      "email": "comandante@fortivus.gov.br",
      "firstName": "Comandante",
      "lastName": "Central",
      "credentials": [
        { "type": "password", "value": "123456", "temporary": false }
      ],
      "realmRoles": ["ROLE_CENTRO_COMANDO_CENTRAL"]
    },
    {
      "username": "operador",
      "enabled": true,
      "email": "operador@fortivus.gov.br",
      "firstName": "Operador",
      "lastName": "Base",
      "credentials": [
        { "type": "password", "value": "123456", "temporary": false }
      ],
      "realmRoles": ["ROLE_CENTRO_COMANDO"]
    },
    {
      "username": "combatente",
      "enabled": true,
      "email": "combatente@fortivus.gov.br",
      "firstName": "Combatente",
      "lastName": "Campo",
      "credentials": [
        { "type": "password", "value": "123456", "temporary": false }
      ],
      "realmRoles": ["ROLE_COMBATENTE"]
    }
  ]
}
