# Fortivus — Variáveis de ambiente (dev)
# Preencha os valores abaixo ou use o Jenkinsfile para injetar via Vault.
# NUNCA commite este arquivo com valores reais.

# secret/fortivus/database
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
KEYCLOAK_POSTGRES_DB=keycloak

# secret/fortivus/keycloak
KEYCLOAK_ADMIN=
KEYCLOAK_ADMIN_PASSWORD=

# secret/fortivus/rabbitmq
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=

# secret/fortivus/storage
S3_ACCESS_KEY=
S3_SECRET_KEY=

# secret/fortivus/nasa-firms
NASA_FIRMS_MAP_KEY=
