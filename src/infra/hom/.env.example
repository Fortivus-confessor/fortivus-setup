# Fortivus — Variáveis de Ambiente (HOM/Produção)
# Copie este arquivo para .env e preencha todos os valores.
# NUNCA commite o arquivo .env com valores reais.

# ──────────────────────────────────────────────────────────────────────────────
# DOMÍNIO E CERTIFICADOS
# ──────────────────────────────────────────────────────────────────────────────

# Domínio principal da aplicação (ex: fortivus.example.com)
# DNS A records necessários:
#   fortivus.example.com    → IP da VPS
#   auth.fortivus.example.com → IP da VPS
#   traefik.fortivus.example.com → IP da VPS
DOMAIN=

# E-mail para notificações do Let's Encrypt (expiração de certificado)
ACME_EMAIL=

# ──────────────────────────────────────────────────────────────────────────────
# BANCO DE DADOS (PostgreSQL)
# ──────────────────────────────────────────────────────────────────────────────

POSTGRES_USER=fortivus
POSTGRES_PASSWORD=
POSTGRES_DB=fortivus
KEYCLOAK_POSTGRES_DB=keycloak

# ──────────────────────────────────────────────────────────────────────────────
# KEYCLOAK (Identity Provider)
# ──────────────────────────────────────────────────────────────────────────────

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# RABBITMQ (Mensageria)
# ──────────────────────────────────────────────────────────────────────────────

RABBITMQ_USERNAME=fortivus
RABBITMQ_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# SEAWEEDFS S3 (Object Storage)
# ──────────────────────────────────────────────────────────────────────────────

S3_ACCESS_KEY=fortivus
S3_SECRET_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# NASA FIRMS (API de Focos de Calor)
# Obtenha sua chave em: https://firms.modaps.eosdis.nasa.gov/api/area/
# ──────────────────────────────────────────────────────────────────────────────

NASA_FIRMS_MAP_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# VAULT — CREDENCIAIS DE APPROLE (preenchidas após rodar ./scripts/vault-init.sh)
# ──────────────────────────────────────────────────────────────────────────────

# Backend (fortivus-v2)
BACKEND_VAULT_ROLE_ID=
BACKEND_VAULT_SECRET_ID=

# Attachment Service
ATTACHMENT_VAULT_ROLE_ID=
ATTACHMENT_VAULT_SECRET_ID=

# Fire Event Service
FIRE_EVENT_VAULT_ROLE_ID=
FIRE_EVENT_VAULT_SECRET_ID=

# ──────────────────────────────────────────────────────────────────────────────
# TRAEFIK DASHBOARD (Autenticação Basic Auth)
# Gere o hash com: htpasswd -nB admin
# Exemplo de saída: admin:$2y$05$...
# Cole apenas o hash (sem o "admin:" prefixo) em TRAEFIK_DASHBOARD_PASSWORD_HASH
# ──────────────────────────────────────────────────────────────────────────────

TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD_HASH=
